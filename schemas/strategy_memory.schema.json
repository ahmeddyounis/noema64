{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noema64.local/schemas/strategy_memory.schema.json",
  "title": "Noema64 Strategy Memory",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "memory_id",
    "game_id",
    "side",
    "ply",
    "phase",
    "plan",
    "targets",
    "opponent_model",
    "last_update"
  ],
  "properties": {
    "schema_version": {
      "const": "strategy-memory.v1.2"
    },
    "memory_id": {
      "type": "string"
    },
    "game_id": {
      "type": "string"
    },
    "side": {
      "enum": ["white", "black"]
    },
    "ply": {
      "type": "integer",
      "minimum": 0
    },
    "phase": {
      "type": "string"
    },
    "plan": {
      "type": "object",
      "additionalProperties": true,
      "required": ["summary", "status", "confidence", "horizon_moves"],
      "properties": {
        "summary": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "horizon_moves": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "targets": {
      "type": "object",
      "additionalProperties": true
    },
    "piece_improvement": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "pawn_breaks": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "opponent_model": {
      "type": "object",
      "additionalProperties": true,
      "required": ["likely_plan", "confidence"],
      "properties": {
        "likely_plan": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "commitments": {
      "type": "array",
      "items": { "type": "string" }
    },
    "refutation_triggers": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "do_not_play_patterns": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "last_update": {
      "type": "object",
      "additionalProperties": true,
      "required": ["decision_id", "move_played", "summary"],
      "properties": {
        "decision_id": { "type": "string" },
        "move_played": { "type": "string" },
        "summary": { "type": "string" }
      }
    },
    "tactical_warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "style_notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
